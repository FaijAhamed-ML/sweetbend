rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL Default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }
    function isAdmin() { 
      return isSignedIn() && (
        hasRole('admin') || 
        request.auth.token.email == 'faijgroups@gmail.com'
      ); 
    }
    function isPOS() { return isAdmin() || hasRole('pos'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Settings ---
    match /settings/website {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isPOS());
      allow list: if isPOS();
      allow create: if true; 
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || isPOS();
    }

    // --- Inquiries ---
    match /inquiries/{inquiryId} {
      allow get: if isPOS() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isPOS() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPOS();
      allow delete: if isAdmin();
    }

    // --- Sales ---
    match /sales/{saleId} {
      allow get: if isPOS() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow list: if isPOS() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow write: if isPOS();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isPOS();
      allow write: if isPOS();
    }
  }
}
