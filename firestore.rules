rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL Default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'faijgroups@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function isPOS() { 
      return isAdmin() || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pos'); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidInvoiceSetting(data) {
      return data.shopName is string && data.shopName.size() <= 100 &&
             data.shopAddress is string && data.shopAddress.size() <= 200 &&
             data.shopPhone is string && data.shopPhone.size() <= 30 &&
             data.footerMessage is string && data.footerMessage.size() <= 200 &&
             data.website is string && data.website.size() <= 100;
    }

    // --- Settings ---
    match /settings/website {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/invoice {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidInvoiceSetting(request.resource.data);
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isPOS());
      allow list: if isPOS();
      allow create: if true; 
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || isPOS();
    }

    // --- Inquiries ---
    match /inquiries/{inquiryId} {
      allow get: if isPOS() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isPOS() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isPOS();
      allow delete: if isAdmin();
    }

    // --- Sales ---
    match /sales/{saleId} {
      allow get: if isPOS() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow list: if isPOS() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow write: if isPOS();
    }

    // --- Active Sessions ---
    match /active_sessions/{sessionId} {
      allow read, write: if isPOS();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read, write: if isPOS();
    }
  }
}
