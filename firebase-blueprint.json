{
  "entities": {
    "Setting": {
      "title": "Website Settings",
      "description": "Global settings for the website",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "tabIconUrl": { "type": "string" },
        "tagline": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "SettingInvoice": {
      "title": "Invoice Settings",
      "description": "Settings for invoice generation",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "shopLogo": { "type": "string" },
        "shopAddress": { "type": "string" },
        "shopPhone": { "type": "string" },
        "footerMessage": { "type": "string" },
        "website": { "type": "string" }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "personalPhone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "pos", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Product": {
      "title": "Sweet Item",
      "description": "Details of a sweet product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "nutritionalInfo": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "photoUrl": { "type": "string" },
        "stockLevel": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Inquiry": {
      "title": "Customer Inquiry",
      "description": "An inquiry sent by a customer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "status"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A record of a transaction",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "type": { "type": "string", "enum": ["pre", "take"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "customerId": { "type": "string" },
        "posId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "System Notification",
      "description": "System generated alerts",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["lowStock", "info"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "status"]
    },
    "POSSession": {
      "title": "Active POS Session",
      "description": "An active shopping cart shared across POS terminals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerId": { "type": "string" },
        "type": { "type": "string", "enum": ["take", "pre"] },
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items"]
    }
  },
  "firestore": {
    "/settings/website": {
      "schema": "Setting",
      "description": "Global website configuration"
    },
    "/settings/invoice": {
      "schema": "SettingInvoice",
      "description": "Invoice template configuration"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Sweet products catalog"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Customer inquiries"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales transactions"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System alerts and notifications"
    },
    "/active_sessions/{sessionId}": {
      "schema": "POSSession",
      "description": "Live POS shopping carts"
    }
  }
}
